<script>
// ==============================
//  STATE & STORAGE
// ==============================
const DB_KEY = 'flowtimer_routines_v2';
let routines = [];
let editingRoutineId = null;
let exercises = []; // builder state
let workoutRoutine = null;
let workoutPlan = []; // flat steps: {type:'exercise'|'rest'|'switch', ...}
let currentStep = 0;
let timeLeft = 0;
let totalTime = 0;
let timer = null;
let isPlaying = false;
let workoutStartTime = 0;
let toDeleteId = null;

function loadDB() {
  try {
    const raw = localStorage.getItem(DB_KEY);
    if (raw) routines = JSON.parse(raw);
  } catch(e) { routines = []; }
}

function saveDB() {
  try { localStorage.setItem(DB_KEY, JSON.stringify(routines)); }
  catch(e) { showToast('Storage full – images may be too large'); }
}

// ==============================
//  NAVIGATION
// ==============================
let currentPage = 'home';

function navTo(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.add('hidden'));
  document.getElementById('page-' + page).classList.remove('hidden');
  currentPage = page;
  // Nav bar visibility
  document.getElementById('bottom-nav').style.display =
    page === 'workout' ? 'none' : 'flex';
  // Active nav
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  const nb = document.getElementById('nav-' + page);
  if (nb) nb.classList.add('active');
}

// ==============================
//  VIBRATION ENGINE
// ==============================
function vibrate(pattern) {
  if (!navigator.vibrate) return;
  try { navigator.vibrate(pattern); } catch(e) {}
}

// Patterns
const VIB_SWITCH = [100, 50, 100, 50, 200];       // side switch - 3 short pulses
const VIB_NEXT   = [80, 40, 80, 40, 80, 40, 300]; // next exercise
const VIB_REST   = [60, 40, 60];                    // rest start
const VIB_END    = [100,60,100,60,100,60,400,80,400]; // workout end
const VIB_TICK   = [30];                             // last 3 seconds tick

// ==============================
//  HOME PAGE
// ==============================
function loadHome() {
  // Check vibration support
  const notice = document.getElementById('vib-notice-home');
  if (!navigator.vibrate) notice.style.display = 'block';

  const el = document.getElementById('routine-list');
  const empty = document.getElementById('empty-state');
  el.innerHTML = '';
  if (routines.length === 0) {
    empty.style.display = 'flex';
    return;
  }
  empty.style.display = 'none';
  routines.forEach(r => {
    const div = document.createElement('div');
    div.className = 'routine-card';
    const total = r.exercises.reduce((a,e) => {
      let s = e.duration;
      if (e.switchSides) s += e.duration; // switch adds same time
      if (e.restEnabled) s += e.restDuration;
      return a + s;
    }, 0);
    const mins = Math.floor(total/60);
    const secs = total % 60;
    div.innerHTML = `
      <div class="exercise-thumb">${r.exercises[0]?.photo
        ? `<img src="${r.exercises[0].photo}" alt="">`
        : '💪'}</div>
      <div class="routine-card-info">
        <h3>${esc(r.name)}</h3>
        <p>${r.exercises.length} exercise${r.exercises.length!==1?'s':''} · ${mins}m ${secs}s</p>
      </div>
      <div class="routine-card-actions">
        <button class="btn btn-ghost btn-small btn-icon" onclick="event.stopPropagation();editRoutine('${r.id}')" title="Edit">✏️</button>
        <button class="btn btn-ghost btn-small btn-icon" onclick="event.stopPropagation();askDelete('${r.id}')" title="Delete">🗑️</button>
      </div>
    `;
    div.addEventListener('click', () => startWorkout(r.id));
    el.appendChild(div);
  });
}

function esc(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ==============================
//  ROUTINE BUILDER
// ==============================
let exerciseIdCounter = 0;

function newRoutine() {
  editingRoutineId = null;
  exercises = [];
  document.getElementById('routine-name').value = '';
  document.getElementById('builder-title').textContent = 'New Routine';
  renderExerciseList();
  // Add one exercise by default
  addExercise();
}

function editRoutine(id) {
  const r = routines.find(x => x.id === id);
  if (!r) return;
  editingRoutineId = id;
  document.getElementById('routine-name').value = r.name;
  document.getElementById('builder-title').textContent = 'Edit Routine';
  // Deep clone
  exercises = r.exercises.map(e => ({...e}));
  exerciseIdCounter = exercises.reduce((m,e) => Math.max(m, parseInt(e.id)||0), 0) + 1;
  renderExerciseList();
  navTo('builder');
}

function addExercise() {
  const id = ++exerciseIdCounter;
  exercises.push({
    id: String(id),
    name: '',
    duration: 30,
    photo: null,
    switchSides: false,
    restEnabled: false,
    restDuration: 15,
    open: true
  });
  renderExerciseList();
  // Scroll to bottom
  setTimeout(() => {
    const sc = document.querySelector('#page-builder .scroll-content');
    sc.scrollTop = sc.scrollHeight;
  }, 50);
}

function removeExercise(id) {
  exercises = exercises.filter(e => e.id !== id);
  renderExerciseList();
}

function toggleExercise(id) {
  const e = exercises.find(x => x.id === id);
  if (e) e.open = !e.open;
  renderExerciseList();
}

function renderExerciseList() {
  const list = document.getElementById('exercise-list');
  list.innerHTML = '';
  exercises.forEach((ex, idx) => {
    const div = document.createElement('div');
    div.className = 'exercise-item';
    div.id = 'ex-item-' + ex.id;
    div.dataset.id = ex.id;

    div.innerHTML = `
      <div class="exercise-header" onclick="toggleExercise('${ex.id}')">
        <span class="drag-handle" title="Drag to reorder">⠿</span>
        <div class="exercise-thumb" id="thumb-${ex.id}">
          ${ex.photo ? `<img src="${ex.photo}" alt="">` : '<span>💪</span>'}
        </div>
        <div class="exercise-header-info">
          <h4>${esc(ex.name) || 'Exercise ' + (idx+1)}</h4>
          <span>${ex.duration}s${ex.switchSides?' · 🔄 Switch':''}${ex.restEnabled?' · '+ex.restDuration+'s rest':''}</span>
        </div>
        <span class="exercise-toggle ${ex.open?'open':''}">⌄</span>
      </div>
      <div class="exercise-body ${ex.open?'open':''}">
        <div class="builder-section" style="margin:0">
          <label>Name</label>
          <input class="input" type="text" value="${esc(ex.name)}" placeholder="e.g. Push-ups"
            oninput="updateEx('${ex.id}','name',this.value)">
        </div>
        <div class="form-row">
          <div class="builder-section" style="margin:0">
            <label>Duration (sec)</label>
            <input class="input" type="number" min="1" max="3600" value="${ex.duration}"
              oninput="updateEx('${ex.id}','duration',parseInt(this.value)||30)">
          </div>
        </div>

        <div class="builder-section" style="margin:0">
          <label>Photo</label>
          <div class="photo-upload-area ${ex.photo?'has-photo':''}" id="photo-area-${ex.id}">
            <input type="file" accept="image/*" onchange="handlePhoto('${ex.id}',this)">
            ${ex.photo
              ? `<img src="${ex.photo}" alt="" onclick="event.stopPropagation()"><button onclick="clearPhoto('${ex.id}');event.stopPropagation()" style="position:absolute;top:6px;right:6px;background:#0009;color:white;border:none;border-radius:50%;width:26px;height:26px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;">✕</button>`
              : `<div class="photo-upload-label"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg><span>Tap to add photo</span></div>`
            }
          </div>
        </div>

        <div class="toggle-row">
          <span>🔄 Switch sides halfway</span>
          <div class="toggle ${ex.switchSides?'on':''}" id="toggle-switch-${ex.id}"
            onclick="toggleSwitch('${ex.id}')"></div>
        </div>

        <div class="toggle-row">
          <span>😮‍💨 Rest after this exercise</span>
          <div class="toggle ${ex.restEnabled?'on':''}" id="toggle-rest-${ex.id}"
            onclick="toggleRest('${ex.id}')"></div>
        </div>
        <div class="rest-fields ${ex.restEnabled?'visible':''}" id="rest-fields-${ex.id}">
          <div style="flex:1">
            <label class="builder-section" style="margin:0">
              <span style="display:block;font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:6px">Rest Duration (sec)</span>
              <input class="input" type="number" min="1" max="600" value="${ex.restDuration}"
                oninput="updateEx('${ex.id}','restDuration',parseInt(this.value)||15)">
            </label>
          </div>
        </div>

        <button class="btn btn-danger btn-small" style="align-self:flex-start" onclick="removeExercise('${ex.id}')">
          🗑 Remove
        </button>
      </div>
    `;
    list.appendChild(div);
  });

  // Drag reorder
  initDragSort(list);
}

function updateEx(id, key, val) {
  const e = exercises.find(x => x.id === id);
  if (!e) return;
  e[key] = val;
  // Update header summary without full re-render
  const item = document.getElementById('ex-item-'+id);
  if (item) {
    const h4 = item.querySelector('h4');
    const span = item.querySelector('.exercise-header-info span');
    const idx = exercises.indexOf(e);
    if (h4) h4.textContent = e.name || 'Exercise '+(idx+1);
    if (span) span.textContent = `${e.duration}s${e.switchSides?' · 🔄 Switch':''}${e.restEnabled?' · '+e.restDuration+'s rest':''}`;
  }
}

function toggleSwitch(id) {
  const e = exercises.find(x => x.id === id);
  if (!e) return;
  e.switchSides = !e.switchSides;
  const t = document.getElementById('toggle-switch-'+id);
  if (t) t.classList.toggle('on', e.switchSides);
  updateEx(id, 'name', e.name); // trigger header update
}

function toggleRest(id) {
  const e = exercises.find(x => x.id === id);
  if (!e) return;
  e.restEnabled = !e.restEnabled;
  const t = document.getElementById('toggle-rest-'+id);
  if (t) t.classList.toggle('on', e.restEnabled);
  const rf = document.getElementById('rest-fields-'+id);
  if (rf) rf.classList.toggle('visible', e.restEnabled);
  updateEx(id, 'name', e.name);
}

function handlePhoto(id, input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    // Compress image
    const img = new Image();
    img.onload = () => {
      const canvas = document.createElement('canvas');
      const MAX = 480;
      let w = img.width, h = img.height;
      if (w > h && w > MAX) { h = h * MAX / w; w = MAX; }
      else if (h > MAX) { w = w * MAX / h; h = MAX; }
      canvas.width = w; canvas.height = h;
      canvas.getContext('2d').drawImage(img, 0, 0, w, h);
      const dataUrl = canvas.toDataURL('image/jpeg', 0.75);
      const e = exercises.find(x => x.id === id);
      if (e) {
        e.photo = dataUrl;
        // Update thumb & area without full re-render
        const thumb = document.getElementById('thumb-'+id);
        if (thumb) thumb.innerHTML = `<img src="${dataUrl}" alt="">`;
        const area = document.getElementById('photo-area-'+id);
        if (area) {
          area.classList.add('has-photo');
          area.innerHTML = `<input type="file" accept="image/*" onchange="handlePhoto('${id}',this)">
            <img src="${dataUrl}" alt="">
            <button onclick="clearPhoto('${id}');event.stopPropagation()" style="position:absolute;top:6px;right:6px;background:#0009;color:white;border:none;border-radius:50%;width:26px;height:26px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;">✕</button>`;
        }
      }
    };
    img.src = ev.target.result;
  };
  reader.readAsDataURL(file);
}

function clearPhoto(id) {
  const e = exercises.find(x => x.id === id);
  if (!e) return;
  e.photo = null;
  const thumb = document.getElementById('thumb-'+id);
  if (thumb) thumb.innerHTML = '<span>💪</span>';
  const area = document.getElementById('photo-area-'+id);
  if (area) {
    area.classList.remove('has-photo');
    area.innerHTML = `<input type="file" accept="image/*" onchange="handlePhoto('${id}',this)">
      <div class="photo-upload-label"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg><span>Tap to add photo</span></div>`;
  }
}

function saveRoutine() {
  const name = document.getElementById('routine-name').value.trim();
  if (!name) { showToast('Please enter a routine name'); return; }
  if (exercises.length === 0) { showToast('Add at least one exercise'); return; }

  const routine = {
    id: editingRoutineId || Date.now().toString(),
    name,
    exercises: exercises.map(e => ({...e, open: undefined}))
  };

  if (editingRoutineId) {
    const idx = routines.findIndex(r => r.id === editingRoutineId);
    if (idx >= 0) routines[idx] = routine;
  } else {
    routines.push(routine);
  }
  saveDB();
  showToast(editingRoutineId ? 'Routine updated!' : 'Routine saved!');
  navTo('home');
  loadHome();
}

// ==============================
//  DRAG SORT
// ==============================
function initDragSort(list) {
  let dragging = null, dragIdx = null;

  list.querySelectorAll('.exercise-item').forEach((item, idx) => {
    const handle = item.querySelector('.drag-handle');
    handle.addEventListener('pointerdown', e => {
      e.stopPropagation();
      dragging = item;
      dragIdx = idx;
      item.classList.add('dragging');
      item.setPointerCapture(e.pointerId);

      const startY = e.clientY;
      const itemH = item.offsetHeight;
      let currentY = startY;

      const onMove = ev => {
        currentY = ev.clientY;
        const diff = currentY - startY;
        item.style.transform = `translateY(${diff}px)`;

        // Find swap target
        const all = [...list.querySelectorAll('.exercise-item:not(.dragging)')];
        all.forEach(other => {
          const rect = other.getBoundingClientRect();
          const mid = rect.top + rect.height / 2;
          if (currentY > mid - 10 && currentY < mid + 10) {
            const otherIdx = [...list.children].indexOf(other);
            if (otherIdx < [...list.children].indexOf(item)) {
              list.insertBefore(item, other);
            } else {
              list.insertBefore(item, other.nextSibling);
            }
          }
        });
      };
      const onUp = () => {
        item.classList.remove('dragging');
        item.style.transform = '';
        // Sync exercises array order
        const newOrder = [...list.querySelectorAll('.exercise-item')].map(el => el.dataset.id);
        exercises = newOrder.map(id => exercises.find(e => e.id === id)).filter(Boolean);
        item.removeEventListener('pointermove', onMove);
        item.removeEventListener('pointerup', onUp);
      };
      item.addEventListener('pointermove', onMove);
      item.addEventListener('pointerup', onUp);
    });
  });
}

// ==============================
//  DELETE
// ==============================
function askDelete(id) {
  toDeleteId = id;
  document.getElementById('delete-modal').classList.remove('hidden');
}
function closeDeleteModal() {
  document.getElementById('delete-modal').classList.add('hidden');
  toDeleteId = null;
}
function confirmDelete() {
  routines = routines.filter(r => r.id !== toDeleteId);
  saveDB();
  closeDeleteModal();
  loadHome();
  showToast('Routine deleted');
}

// ==============================
//  WORKOUT ENGINE
// ==============================
function buildPlan(routine) {
  const plan = [];
  routine.exercises.forEach((ex, idx) => {
    const halfTime = Math.floor(ex.duration / 2);
    const remTime  = ex.duration - halfTime;

    if (ex.switchSides) {
      plan.push({ type: 'exercise', label: ex.name, sub: 'Side 1', duration: halfTime, photo: ex.photo, exIdx: idx, totalExercises: routine.exercises.length, isSwitch: false });
      plan.push({ type: 'switch',   label: ex.name, sub: 'Switch sides!', duration: remTime,  photo: ex.photo, exIdx: idx, totalExercises: routine.exercises.length, isSwitch: true  });
    } else {
      plan.push({ type: 'exercise', label: ex.name, sub: '', duration: ex.duration, photo: ex.photo, exIdx: idx, totalExercises: routine.exercises.length, isSwitch: false });
    }

    if (ex.restEnabled) {
      plan.push({ type: 'rest', label: 'Rest', sub: (idx+1 < routine.exercises.length ? 'Next: ' + routine.exercises[idx+1].name : 'Almost done!'), duration: ex.restDuration, photo: null, exIdx: idx, totalExercises: routine.exercises.length, isSwitch: false });
    }
  });
  return plan;
}

function startWorkout(id) {
  workoutRoutine = routines.find(r => r.id === id);
  if (!workoutRoutine || workoutRoutine.exercises.length === 0) {
    showToast('No exercises in this routine'); return;
  }
  workoutPlan = buildPlan(workoutRoutine);
  currentStep = 0;
  workoutStartTime = Date.now();
  document.getElementById('workout-routine-name').textContent = workoutRoutine.name;
  navTo('workout');
  showCountdown(() => {
    loadStep(currentStep);
    setPlaying(true);
  });
}

function showCountdown(cb) {
  const overlay = document.getElementById('countdown-overlay');
  const num = document.getElementById('countdown-num');
  overlay.classList.remove('hidden');
  let n = 3;
  vibrate(VIB_TICK);
  const tick = () => {
    num.textContent = n;
    num.classList.remove('animate');
    void num.offsetWidth;
    num.classList.add('animate');
    if (n > 0) { vibrate(VIB_TICK); n--; setTimeout(tick, 900); }
    else { overlay.classList.add('hidden'); cb(); }
  };
  tick();
}

function loadStep(idx) {
  if (idx >= workoutPlan.length) { finishWorkout(); return; }
  const step = workoutPlan[idx];
  timeLeft = step.duration;
  totalTime = step.duration;

  const badge = document.getElementById('workout-phase-badge');
  const photo = document.getElementById('exercise-photo-full');
  const nameEl = document.getElementById('workout-name');
  const subEl = document.getElementById('workout-sub');
  const progress = document.getElementById('ring-progress');
  const timeDisp = document.getElementById('timer-display');

  badge.className = 'workout-phase-badge ' + (step.type === 'rest' ? 'rest' : step.isSwitch ? 'switch' : 'active');
  badge.textContent = step.type === 'rest' ? '😮‍💨 REST' : step.isSwitch ? '🔄 SWITCH SIDES' : '💪 EXERCISE';

  nameEl.textContent = step.label;
  subEl.textContent  = step.sub;

  // Photo
  photo.className = 'exercise-photo-full' + (step.type === 'rest' ? ' rest-phase' : '');
  photo.innerHTML = step.photo
    ? `<img src="${step.photo}" alt="${esc(step.label)}">`
    : `<span class="no-photo-icon">${step.type==='rest'?'😮‍💨':'💪'}</span>`;

  // Ring color
  progress.className = 'timer-ring-progress' + (step.type==='rest'?' rest':step.isSwitch?' switch':'');

  // Exercise count
  const exNum = workoutPlan.filter((s, i) => i <= idx && s.type !== 'rest').length;
  const exTotal = workoutPlan.filter(s => s.type !== 'rest').length;
  document.getElementById('ex-count').textContent = step.type === 'rest' ? 'Rest' : `${exNum} / ${exTotal}`;

  updateTimerDisplay();
  updateDots();
}

function updateTimerDisplay() {
  const pct = timeLeft / totalTime;
  const CIRC = 515;
  document.getElementById('ring-progress').style.strokeDashoffset = CIRC * (1 - pct);

  const step = workoutPlan[currentStep];
  const d = document.getElementById('timer-display');
  const m = Math.floor(timeLeft / 60);
  const s = timeLeft % 60;
  d.className = 'time' + (step?.type==='rest'?' rest':step?.isSwitch?' switch':'');
  d.textContent = `${m}:${String(s).padStart(2,'0')}`;
}

function updateDots() {
  const container = document.getElementById('progress-dots');
  container.innerHTML = '';
  // Show exercise-level dots
  const exSteps = workoutPlan.filter(s => !s.isSwitch); // each exercise appears once
  workoutPlan.forEach((s, i) => {
    if (s.isSwitch) return; // skip switch sub-steps for dots
    const d = document.createElement('div');
    const isDone = i < currentStep && !s.isSwitch;
    const isCurr = i === currentStep || (s.type !== 'rest' && workoutPlan[currentStep]?.exIdx === s.exIdx);
    d.className = 'dot' + (isDone ? ' done' : isCurr ? ' current' : s.type==='rest' ? ' rest' : '');
    container.appendChild(d);
  });
}

function tick() {
  timeLeft--;
  if (timeLeft <= 0) {
    timeLeft = 0;
    updateTimerDisplay();
    goNextStep();
    return;
  }
  // Last 3 seconds tick
  if (timeLeft <= 3) vibrate(VIB_TICK);
  updateTimerDisplay();
}

function goNextStep() {
  clearInterval(timer);
  timer = null;
  const step = workoutPlan[currentStep];

  if (currentStep + 1 >= workoutPlan.length) {
    finishWorkout();
    return;
  }

  currentStep++;
  const nextStep = workoutPlan[currentStep];

  // Vibrate based on transition type
  if (step.type === 'exercise' && !step.isSwitch) {
    // Moving to switch or rest or next exercise
    if (nextStep.isSwitch) vibrate(VIB_SWITCH);
    else if (nextStep.type === 'rest') vibrate(VIB_REST);
    else vibrate(VIB_NEXT);
  } else if (step.isSwitch) {
    vibrate(VIB_SWITCH); // second half alert
  } else if (step.type === 'rest') {
    vibrate(VIB_NEXT);
  }

  loadStep(currentStep);
  if (isPlaying) startTimer();
}

function startTimer() {
  clearInterval(timer);
  timer = setInterval(tick, 1000);
}

function setPlaying(v) {
  isPlaying = v;
  document.getElementById('btn-play').textContent = v ? '⏸' : '▶';
  if (v) startTimer();
  else { clearInterval(timer); timer = null; }
}

function togglePlay() {
  setPlaying(!isPlaying);
}

function nextExercise() {
  clearInterval(timer); timer = null;
  if (currentStep + 1 >= workoutPlan.length) { finishWorkout(); return; }
  currentStep++;
  loadStep(currentStep);
  if (isPlaying) startTimer();
}

function prevExercise() {
  clearInterval(timer); timer = null;
  if (currentStep > 0) currentStep--;
  loadStep(currentStep);
  if (isPlaying) startTimer();
}

function stopWorkout() {
  clearInterval(timer); timer = null;
  isPlaying = false;
  navTo('home');
  loadHome();
}

function finishWorkout() {
  clearInterval(timer); timer = null;
  isPlaying = false;
  vibrate(VIB_END);
  const elapsed = Math.floor((Date.now() - workoutStartTime) / 1000);
  const m = Math.floor(elapsed / 60);
  const s = elapsed % 60;
  document.getElementById('sum-exercises').textContent = workoutRoutine.exercises.length;
  document.getElementById('sum-time').textContent = `${m}:${String(s).padStart(2,'0')}`;
  document.getElementById('summary-modal').classList.remove('hidden');
}

function closeSummary() {
  document.getElementById('summary-modal').classList.add('hidden');
  navTo('home');
  loadHome();
}

function restartWorkout() {
  document.getElementById('summary-modal').classList.add('hidden');
  startWorkout(workoutRoutine.id);
}

// ==============================
//  TOAST
// ==============================
let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
}

// ==============================
//  PWA / SERVICE WORKER
// ==============================
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('sw.js').catch(() => {});
}

// Wake lock (keep screen on during workout)
let wakeLock = null;
async function requestWakeLock() {
  try {
    if ('wakeLock' in navigator) {
      wakeLock = await navigator.wakeLock.request('screen');
    }
  } catch(e) {}
}
async function releaseWakeLock() {
  try { if (wakeLock) { await wakeLock.release(); wakeLock = null; } } catch(e) {}
}

// Override startWorkout to add wake lock
const _startWorkout = startWorkout;
// Handled inline above

// Keep screen on during workout
document.addEventListener('visibilitychange', async () => {
  if (document.visibilityState === 'visible' && currentPage === 'workout') {
    await requestWakeLock();
  }
});

// ==============================
//  INIT
// ==============================
loadDB();
loadHome();

// Check vibration on load
if (!navigator.vibrate) {
  document.getElementById('vib-notice-home').style.display = 'block';
}
</script>

<!-- Service Worker inline via blob approach -->

<script id="sw-src" type="text/plain">
const CACHE = 'flowtimer-v1';
self.addEventListener('install', e => {
  e.waitUntil(caches.open(CACHE).then(c => c.addAll(['./', './index.html'])));
  self.skipWaiting();
});
self.addEventListener('activate', e => {
  e.waitUntil(clients.claim());
});
self.addEventListener('fetch', e => {
  e.respondWith(caches.match(e.request).then(r => r || fetch(e.request).catch(() => caches.match('./index.html'))));
});
</script>

