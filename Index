<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="FlowTimer">
<meta name="theme-color" content="#2d0a4e">
<title>FlowTimer – Workout Routines</title>
<link rel="manifest" href="manifest.json">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0e0118;
    --surface: #1a0530;
    --surface2: #241040;
    --rim: #3d1a6e;
    --accent: #a855f7;
    --accent2: #7c3aed;
    --accent3: #c084fc;
    --glow: #a855f733;
    --text: #f3e8ff;
    --muted: #9d7ec0;
    --danger: #f43f5e;
    --success: #34d399;
    --warn: #fbbf24;
    --rest: #38bdf8;
    --radius: 16px;
    --font-head: 'Bebas Neue', sans-serif;
    --font-body: 'DM Sans', sans-serif;
  }

- { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

html, body {
height: 100%; overflow: hidden;
background: var(–bg);
color: var(–text);
font-family: var(–font-body);
overscroll-behavior: none;
}

/* ===== SCROLLABLE PAGES ===== */
.page {
position: fixed; inset: 0;
display: flex; flex-direction: column;
overflow: hidden;
transition: opacity .3s, transform .3s;
}
.page.hidden { opacity: 0; pointer-events: none; transform: translateY(20px); }

/* ===== NOISE TEXTURE ===== */
body::before {
content: ‘’;
position: fixed; inset: 0; z-index: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘noise’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23noise)’ opacity=‘0.04’/%3E%3C/svg%3E”);
opacity: .4; pointer-events: none;
}

/* ===== ORBS ===== */
.orb {
position: fixed; border-radius: 50%;
filter: blur(80px); opacity: .25; pointer-events: none; z-index: 0;
}
.orb1 { width: 400px; height: 400px; background: #7c3aed; top: -150px; right: -100px; }
.orb2 { width: 300px; height: 300px; background: #a855f7; bottom: -100px; left: -50px; }

/* ===== TOP BAR ===== */
.topbar {
position: relative; z-index: 10;
display: flex; align-items: center; justify-content: space-between;
padding: 16px 20px 12px;
border-bottom: 1px solid var(–rim);
background: linear-gradient(180deg, #1a053088 0%, transparent 100%);
flex-shrink: 0;
}
.topbar h1 {
font-family: var(–font-head);
font-size: 28px; letter-spacing: 2px;
background: linear-gradient(135deg, var(–accent3), var(–accent));
-webkit-background-clip: text; -webkit-text-fill-color: transparent;
}

/* ===== BUTTONS ===== */
.btn {
display: inline-flex; align-items: center; justify-content: center; gap: 8px;
padding: 10px 20px; border-radius: 100px;
border: none; cursor: pointer;
font-family: var(–font-body); font-size: 14px; font-weight: 600;
transition: all .2s; text-decoration: none;
position: relative; overflow: hidden;
-webkit-user-select: none; user-select: none;
}
.btn::after {
content: ‘’; position: absolute; inset: 0;
background: white; opacity: 0;
transition: opacity .15s;
}
.btn:active::after { opacity: .1; }
.btn-primary {
background: linear-gradient(135deg, var(–accent2), var(–accent));
color: white;
box-shadow: 0 4px 20px var(–glow);
}
.btn-primary:hover { box-shadow: 0 6px 28px #a855f766; transform: translateY(-1px); }
.btn-ghost {
background: var(–surface2); color: var(–text);
border: 1px solid var(–rim);
}
.btn-ghost:hover { background: var(–rim); }
.btn-danger { background: #4c0519; color: var(–danger); border: 1px solid #be123c44; }
.btn-danger:hover { background: #7f1d1d; }
.btn-small { padding: 6px 14px; font-size: 13px; }
.btn-icon {
width: 40px; height: 40px; padding: 0; border-radius: 50%;
background: var(–surface2); border: 1px solid var(–rim); color: var(–text);
font-size: 18px;
}
.btn-icon:hover { background: var(–rim); }

/* ===== SCROLLABLE CONTENT ===== */
.scroll-content {
flex: 1; overflow-y: auto; overflow-x: hidden;
padding: 16px 20px 100px;
position: relative; z-index: 1;
-webkit-overflow-scrolling: touch;
}
.scroll-content::-webkit-scrollbar { width: 4px; }
.scroll-content::-webkit-scrollbar-track { background: transparent; }
.scroll-content::-webkit-scrollbar-thumb { background: var(–rim); border-radius: 2px; }

/* ===== HOME PAGE ===== */
#page-home .empty-state {
display: flex; flex-direction: column; align-items: center;
justify-content: center; gap: 16px;
padding: 60px 20px; text-align: center;
color: var(–muted);
}
#page-home .empty-state svg { opacity: .4; }
#page-home .empty-state p { font-size: 15px; max-width: 240px; line-height: 1.5; }

.routine-card {
background: var(–surface);
border: 1px solid var(–rim);
border-radius: var(–radius);
padding: 16px;
margin-bottom: 12px;
display: flex; align-items: center; gap: 14px;
cursor: pointer;
transition: all .2s;
position: relative; overflow: hidden;
}
.routine-card::before {
content: ‘’; position: absolute; left: 0; top: 0; bottom: 0;
width: 3px; background: linear-gradient(180deg, var(–accent), var(–accent2));
border-radius: 3px 0 0 3px;
}
.routine-card:hover { background: var(–surface2); transform: translateX(2px); }
.routine-card:active { transform: scale(.98); }
.routine-card-info { flex: 1; }
.routine-card-info h3 { font-size: 16px; font-weight: 600; margin-bottom: 4px; }
.routine-card-info p { font-size: 13px; color: var(–muted); }
.routine-card-actions { display: flex; gap: 8px; }

/* ===== ROUTINE BUILDER ===== */
#page-builder { background: var(–bg); }
.builder-section { margin-bottom: 20px; }
.builder-section label {
display: block; font-size: 12px; font-weight: 600;
letter-spacing: 1px; text-transform: uppercase;
color: var(–muted); margin-bottom: 8px;
}
.input {
width: 100%; background: var(–surface);
border: 1px solid var(–rim); border-radius: 10px;
padding: 12px 14px; color: var(–text);
font-family: var(–font-body); font-size: 15px;
outline: none; transition: border-color .2s;
-webkit-appearance: none;
}
.input:focus { border-color: var(–accent); box-shadow: 0 0 0 3px var(–glow); }
.input::placeholder { color: var(–muted); }
input[type=number].input { -moz-appearance: textfield; }
input[type=number].input::-webkit-inner-spin-button,
input[type=number].input::-webkit-outer-spin-button { -webkit-appearance: none; }

.exercise-item {
background: var(–surface);
border: 1px solid var(–rim);
border-radius: var(–radius);
margin-bottom: 12px;
overflow: hidden;
transition: box-shadow .2s;
}
.exercise-item.dragging { box-shadow: 0 8px 32px #a855f744; opacity: .85; }
.exercise-header {
display: flex; align-items: center; gap: 12px;
padding: 12px 14px;
cursor: pointer;
background: var(–surface2);
border-bottom: 1px solid var(–rim);
}
.exercise-header .drag-handle {
color: var(–muted); cursor: grab; font-size: 16px;
touch-action: none;
}
.exercise-header .drag-handle:active { cursor: grabbing; }
.exercise-thumb {
width: 40px; height: 40px; border-radius: 8px;
object-fit: cover; background: var(–rim);
flex-shrink: 0; display: flex; align-items: center; justify-content: center;
overflow: hidden; color: var(–muted); font-size: 20px;
}
.exercise-thumb img { width: 100%; height: 100%; object-fit: cover; }
.exercise-header-info { flex: 1; min-width: 0; }
.exercise-header-info h4 {
font-size: 14px; font-weight: 600;
white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.exercise-header-info span { font-size: 12px; color: var(–muted); }
.exercise-toggle { color: var(–muted); font-size: 18px; transition: transform .2s; }
.exercise-toggle.open { transform: rotate(180deg); }

.exercise-body {
padding: 14px;
display: none;
flex-direction: column; gap: 12px;
}
.exercise-body.open { display: flex; }

.form-row { display: flex; gap: 10px; }
.form-row > * { flex: 1; }

.toggle-row {
display: flex; align-items: center; justify-content: space-between;
background: var(–surface2); border-radius: 10px;
padding: 10px 14px;
}
.toggle-row span { font-size: 13px; color: var(–text); }
.toggle {
width: 44px; height: 24px; background: var(–surface);
border-radius: 12px; border: 1px solid var(–rim);
position: relative; cursor: pointer;
transition: background .2s;
flex-shrink: 0;
}
.toggle.on { background: var(–accent2); border-color: var(–accent); }
.toggle::after {
content: ‘’; position: absolute;
width: 18px; height: 18px; border-radius: 50%;
background: white; top: 2px; left: 2px;
transition: transform .2s;
box-shadow: 0 1px 4px #0006;
}
.toggle.on::after { transform: translateX(20px); }

.photo-upload-area {
border: 2px dashed var(–rim); border-radius: 10px;
padding: 20px; text-align: center;
cursor: pointer; transition: border-color .2s;
position: relative; overflow: hidden;
min-height: 80px; display: flex; align-items: center; justify-content: center;
}
.photo-upload-area:hover { border-color: var(–accent); }
.photo-upload-area.has-photo { border-style: solid; border-color: var(–accent2); padding: 0; }
.photo-upload-area input[type=file] {
position: absolute; inset: 0; opacity: 0; cursor: pointer;
width: 100%; height: 100%;
}
.photo-upload-area img {
width: 100%; max-height: 160px; object-fit: cover;
border-radius: 8px;
}
.photo-upload-label {
display: flex; flex-direction: column; align-items: center; gap: 6px;
color: var(–muted); pointer-events: none;
}
.photo-upload-label span { font-size: 13px; }

.rest-fields { display: none; }
.rest-fields.visible { display: flex; gap: 10px; }

/* ===== ACTIVE WORKOUT ===== */
#page-workout {
background: var(–bg);
display: flex; flex-direction: column;
}
#page-workout .topbar { padding: 12px 16px; }

.workout-main {
flex: 1; display: flex; flex-direction: column;
align-items: center; justify-content: center;
padding: 12px 20px;
position: relative; z-index: 1; overflow: hidden;
}

.exercise-photo-full {
width: min(280px, 75vw); height: min(280px, 75vw);
border-radius: 20px;
object-fit: cover;
border: 2px solid var(–rim);
margin-bottom: 20px;
flex-shrink: 0;
background: var(–surface);
display: flex; align-items: center; justify-content: center;
overflow: hidden;
box-shadow: 0 0 60px var(–glow);
transition: box-shadow .5s;
}
.exercise-photo-full img {
width: 100%; height: 100%; object-fit: cover; border-radius: 18px;
}
.exercise-photo-full.rest-phase {
box-shadow: 0 0 60px #38bdf833;
border-color: var(–rest);
}
.exercise-photo-full .no-photo-icon {
font-size: 64px; color: var(–muted); opacity: .4;
}

.workout-phase-badge {
font-size: 11px; font-weight: 700; letter-spacing: 2px;
text-transform: uppercase; padding: 4px 12px;
border-radius: 100px; margin-bottom: 8px;
background: var(–surface2); color: var(–muted);
border: 1px solid var(–rim);
transition: background .3s, color .3s;
}
.workout-phase-badge.active { background: #3d1a6e; color: var(–accent3); border-color: var(–accent); }
.workout-phase-badge.rest { background: #0c2a3d; color: var(–rest); border-color: #38bdf8; }
.workout-phase-badge.switch { background: #3d2800; color: var(–warn); border-color: var(–warn); }

.workout-name {
font-family: var(–font-head);
font-size: clamp(26px, 7vw, 38px);
letter-spacing: 2px;
text-align: center;
line-height: 1.1;
margin-bottom: 6px;
max-width: 320px;
}
.workout-sub {
font-size: 13px; color: var(–muted);
margin-bottom: 20px; text-align: center;
}

/* TIMER RING */
.timer-ring-container {
position: relative;
width: min(180px, 48vw); height: min(180px, 48vw);
flex-shrink: 0; margin-bottom: 20px;
}
.timer-ring-svg {
transform: rotate(-90deg);
width: 100%; height: 100%;
}
.timer-ring-track {
fill: none; stroke: var(–surface2);
stroke-width: 8;
}
.timer-ring-progress {
fill: none;
stroke-width: 8;
stroke-linecap: round;
transition: stroke-dashoffset .5s linear, stroke .3s;
stroke: var(–accent);
}
.timer-ring-progress.rest { stroke: var(–rest); }
.timer-ring-progress.switch { stroke: var(–warn); }
.timer-display {
position: absolute; inset: 0;
display: flex; flex-direction: column;
align-items: center; justify-content: center;
}
.timer-display .time {
font-family: var(–font-head);
font-size: clamp(40px, 12vw, 56px);
letter-spacing: 2px; line-height: 1;
}
.timer-display .time.rest { color: var(–rest); }
.timer-display .time.switch { color: var(–warn); }
.timer-display .ex-count { font-size: 12px; color: var(–muted); margin-top: 2px; }

.workout-controls {
display: flex; align-items: center; gap: 14px;
margin-bottom: 12px;
}
.btn-play {
width: 64px; height: 64px; border-radius: 50%;
background: linear-gradient(135deg, var(–accent2), var(–accent));
border: none; cursor: pointer;
display: flex; align-items: center; justify-content: center;
font-size: 24px; color: white;
box-shadow: 0 4px 24px var(–glow);
transition: all .2s;
-webkit-user-select: none; user-select: none;
}
.btn-play:active { transform: scale(.93); }

.progress-dots {
display: flex; gap: 6px; flex-wrap: wrap;
justify-content: center; padding: 0 20px;
max-width: 320px;
}
.dot {
width: 8px; height: 8px; border-radius: 50%;
background: var(–rim); transition: background .3s;
flex-shrink: 0;
}
.dot.done { background: var(–accent2); }
.dot.current { background: var(–accent3); box-shadow: 0 0 6px var(–accent); }
.dot.rest { background: var(–rest); }

/* ===== MODALS ===== */
.modal-overlay {
position: fixed; inset: 0; z-index: 100;
background: #0009;
display: flex; align-items: flex-end; justify-content: center;
transition: opacity .2s;
backdrop-filter: blur(4px);
}
.modal-overlay.hidden { opacity: 0; pointer-events: none; }
.modal {
background: var(–surface);
border: 1px solid var(–rim);
border-radius: 20px 20px 0 0;
padding: 20px 20px 40px;
width: 100%; max-width: 500px;
max-height: 80vh; overflow-y: auto;
transform: translateY(0);
transition: transform .3s;
}
.modal-overlay.hidden .modal { transform: translateY(100%); }
.modal-handle {
width: 40px; height: 4px; border-radius: 2px;
background: var(–rim); margin: 0 auto 16px;
}
.modal h2 {
font-family: var(–font-head); font-size: 24px;
letter-spacing: 1px; margin-bottom: 16px;
}

/* ===== TOAST ===== */
.toast {
position: fixed; bottom: 24px; left: 50%; z-index: 200;
transform: translateX(-50%) translateY(80px);
background: var(–surface2); border: 1px solid var(–rim);
border-radius: 100px; padding: 10px 20px;
font-size: 13px; font-weight: 500;
white-space: nowrap;
transition: transform .3s, opacity .3s;
pointer-events: none;
opacity: 0;
}
.toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }

/* ===== BOTTOM NAV ===== */
.bottom-nav {
position: fixed; bottom: 0; left: 0; right: 0; z-index: 50;
display: flex; justify-content: space-around;
background: var(–surface);
border-top: 1px solid var(–rim);
padding: 8px 0 max(8px, env(safe-area-inset-bottom));
}
.nav-btn {
display: flex; flex-direction: column; align-items: center; gap: 3px;
padding: 6px 20px; cursor: pointer;
background: none; border: none; color: var(–muted);
font-family: var(–font-body); font-size: 10px; font-weight: 600;
letter-spacing: .5px; text-transform: uppercase;
transition: color .2s;
-webkit-user-select: none; user-select: none;
}
.nav-btn.active { color: var(–accent3); }
.nav-btn svg { transition: transform .2s; }
.nav-btn.active svg { transform: translateY(-2px); }

/* ===== VIBRATION WARNING ===== */
.vib-notice {
background: #2d1a00; border: 1px solid #7c3a0044;
border-radius: 10px; padding: 10px 14px;
font-size: 12px; color: var(–warn);
margin-bottom: 16px; line-height: 1.5;
display: none;
}

/* ===== SECTION DIVIDER ===== */
.divider {
display: flex; align-items: center; gap: 10px;
margin: 20px 0 14px; color: var(–muted);
font-size: 11px; font-weight: 700;
letter-spacing: 1.5px; text-transform: uppercase;
}
.divider::before, .divider::after {
content: ‘’; flex: 1; height: 1px; background: var(–rim);
}

/* Chips for side-switch label */
.chip {
display: inline-block; padding: 2px 8px;
background: var(–surface2); border-radius: 100px;
font-size: 11px; color: var(–muted);
border: 1px solid var(–rim); margin-top: 3px;
}
.chip.active { background: #3d2800; color: var(–warn); border-color: var(–warn); }

/* ===== PULSING SWITCH INDICATOR ===== */
@keyframes pulse-warn {
0%, 100% { box-shadow: 0 0 20px #fbbf2444; }
50% { box-shadow: 0 0 50px #fbbf24aa; }
}
.switch-pulse { animation: pulse-warn .6s infinite; }

/* ===== COUNTDOWN OVERLAY ===== */
.countdown-overlay {
position: fixed; inset: 0; z-index: 90;
background: #0a0118ee;
display: flex; flex-direction: column;
align-items: center; justify-content: center;
transition: opacity .4s;
}
.countdown-overlay.hidden { opacity: 0; pointer-events: none; }
.countdown-num {
font-family: var(–font-head);
font-size: 120px; letter-spacing: 4px;
background: linear-gradient(135deg, var(–accent3), var(–accent));
-webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.countdown-label { color: var(–muted); font-size: 14px; letter-spacing: 2px; text-transform: uppercase; }

@keyframes pop {
0% { transform: scale(.4); opacity: 0; }
60% { transform: scale(1.15); }
100% { transform: scale(1); opacity: 1; }
}
.countdown-num.animate { animation: pop .4s ease-out; }

/* ===== SUMMARY ===== */
.summary-grid {
display: grid; grid-template-columns: 1fr 1fr;
gap: 12px; margin-bottom: 20px;
}
.summary-stat {
background: var(–surface2); border-radius: 12px;
border: 1px solid var(–rim);
padding: 14px; text-align: center;
}
.summary-stat .val {
font-family: var(–font-head); font-size: 32px;
background: linear-gradient(135deg, var(–accent3), var(–accent));
-webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.summary-stat .lbl { font-size: 11px; color: var(–muted); text-transform: uppercase; letter-spacing: 1px; }

/* ===== SAFE AREA ===== */
.safe-top { padding-top: env(safe-area-inset-top); }
</style>

</head>
